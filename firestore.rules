rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: Firebase Auth UID
    // Fields:
    //   - syncId: string (required, max 20 chars)
    //
    // Collection: tasks
    // Document ID: UUID
    // Fields:
    //   - id: string (required)
    //   - title: string (required, max 200 chars)
    //   - description: string (optional, max 2000 chars)
    //   - priority: string ('low', 'medium', 'high')
    //   - status: string ('todo', 'in-progress', 'done')
    //   - tags: list of strings (max 20 items)
    //   - dueDate: string (optional)
    //   - syncId: string (required, max 20 chars)
    //   - createdAt: number (required)
    //   - subtasks: list of objects (optional)
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasOnly(['syncId']) &&
             data.syncId is string &&
             data.syncId.size() > 0 &&
             data.syncId.size() <= 20;
    }

    function isValidTask(data) {
      let hasRequired = data.keys().hasAll(['id', 'title', 'priority', 'status', 'syncId', 'createdAt']);
      let hasValidTypes = data.id is string &&
                          data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
                          data.priority in ['low', 'medium', 'high'] &&
                          data.status in ['todo', 'in-progress', 'done'] &&
                          data.syncId is string && data.syncId.size() > 0 && data.syncId.size() <= 20 &&
                          data.createdAt is number;
      
      let validDesc = !('description' in data) || (data.description is string && data.description.size() <= 2000);
      let validDueDate = !('dueDate' in data) || (data.dueDate is string && data.dueDate.size() <= 50);
      let validTags = !('tags' in data) || (data.tags is list && data.tags.size() <= 20);
      let validSubtasks = !('subtasks' in data) || (data.subtasks is list && data.subtasks.size() <= 50);
      let validFocusMinutes = !('totalFocusMinutes' in data) || (data.totalFocusMinutes is number);
      let validLastFocus = !('lastFocusSession' in data) || (data.lastFocusSession is number);
      let validAttachments = !('attachments' in data) || (data.attachments is list && data.attachments.size() <= 20);

      return hasRequired && hasValidTypes && validDesc && validDueDate && validTags && validSubtasks && validFocusMinutes && validLastFocus && validAttachments;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if isOwner(userId);
    }

    match /tasks/{taskId} {
      // Allow read if the document has a syncId. 
      // This allows unauthenticated devices to sync if they know the exact syncId to query.
      allow read: if resource.data.syncId is string;
      
      allow create: if isValidTask(request.resource.data);
      
      allow update: if isValidTask(request.resource.data) && 
                       resource.data.syncId == request.resource.data.syncId;
                       
      allow delete: if resource.data.syncId is string;
    }

    match /habitCompletions/{completionId} {
      allow read: if resource.data.syncId is string;
      allow create: if request.resource.data.keys().hasAll(['routineId', 'syncId', 'timestamp', 'date']) &&
                       request.resource.data.routineId is string &&
                       request.resource.data.syncId is string &&
                       request.resource.data.timestamp is number &&
                       request.resource.data.date is string;
      allow delete: if resource.data.syncId is string;
    }

    // New collection for cross-device pairing
    match /handshakes/{code} {
      // Allow the PC to find the handshake doc via the 12-char code
      // We limit the read to 'get' only so people can't 'list' (browse) all active codes
      allow get: if true; 
      
      // Allow the Mobile device to create the handshake
      // and allow the PC to update it (e.g., to mark it as 'claimed')
      allow create, update: if true; 
      
      // Optional: Add validation to ensure the code is 12 chars
      allow create: if code.size() == 12 
                    && request.resource.data.syncId is string;
    }

    match /settings/{syncId} {
      allow read: if true;
      allow write: if true;
      allow get: if true; 
      allow list: if false;
    }
  }
}
